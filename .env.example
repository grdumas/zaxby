# OpenSearch Configuration
# Copy this file to .env and fill in your actual credentials

# Connection Details
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# SSL Configuration
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# Index names
# Production Zathras data uses two indices: canonical run documents vs exploded timeseries points.
# See docs/guides/OPENSEARCH_CONNECTION_GUIDE.md ("Two-index model").
#
# Current dashboard code reads OPENSEARCH_INDEX only (single index). Set it to your
# run/results index (typically zathras-results).
#
# OPENSEARCH_INDEX_RESULTS and OPENSEARCH_INDEX_TIMESERIES document the split for operators and
# will be consumed by index routing in src/opensearch_client.py (Phase 0). Until then, keep
# OPENSEARCH_INDEX aligned with OPENSEARCH_INDEX_RESULTS when both are set.
OPENSEARCH_INDEX=zathras-results
OPENSEARCH_INDEX_RESULTS=zathras-results
OPENSEARCH_INDEX_TIMESERIES=zathras-timeseries

# Dashboard Mode
# Set to 'opensearch' or 'synthetic'
DATA_MODE=opensearch
