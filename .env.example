# OpenSearch Configuration
# Copy this file to .env and fill in your actual credentials

# Connection Details
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# SSL Configuration
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# Index names
# Production Zathras data uses two indices: canonical run documents vs exploded timeseries points.
# See docs/guides/OPENSEARCH_CONNECTION_GUIDE.md ("Two-index model").
#
# Run/results index: BenchmarkDataSource uses OPENSEARCH_INDEX_RESULTS if set, else OPENSEARCH_INDEX.
# Set OPENSEARCH_INDEX_TIMESERIES for point-level queries (search_timeseries, fetch_timeseries_for_document).
# When both OPENSEARCH_INDEX and OPENSEARCH_INDEX_RESULTS are set, RESULTS wins for the results index.
#
# Single-index migration: if you previously only set OPENSEARCH_INDEX, keep it on your run/results
# index name, then add OPENSEARCH_INDEX_RESULTS (same value) and OPENSEARCH_INDEX_TIMESERIES when ready.
OPENSEARCH_INDEX=zathras-results
OPENSEARCH_INDEX_RESULTS=zathras-results
OPENSEARCH_INDEX_TIMESERIES=zathras-timeseries

# OpenSearch Dashboards (optional — enables “View in OpenSearch Discover” deep links from the investigation view)
# Base URL only, e.g. https://your-cluster.example.com:5601 (no /app path)
# OPENSEARCH_DASHBOARDS_BASE_URL=

# Dashboard Mode
# Set to 'opensearch' or 'synthetic'
DATA_MODE=opensearch
# If DATA_MODE=opensearch and the initial load fails, the app does NOT fall back to synthetic unless you opt in:
# ZAXBY_USE_SYNTHETIC_AFTER_OPENSEARCH_FAILURE=1
